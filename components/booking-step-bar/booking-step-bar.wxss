.step-bar {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 32rpx 24rpx 16rpx;
  background: #ffffff;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #e8e8e8;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999999;
  font-weight: 600;
  z-index: 1;
}

.step-circle.active {
  border-color: #1a1a1a;
  background: #1a1a1a;
  color: #ffffff;
}

.step-circle.done {
  border-color: #c8a97e;
  background: #c8a97e;
  color: #ffffff;
}

.check { font-size: 28rpx; }

.step-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
  white-space: nowrap;
}

.step-label.active {
  color: #1a1a1a;
  font-weight: 600;
}

.step-line {
  position: absolute;
  top: 28rpx;
  left: 50%;
  width: 100%;
  height: 2rpx;
  background: #e8e8e8;
  z-index: 0;
}
