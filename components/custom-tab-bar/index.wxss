.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  border-top: 1rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  transition: all 0.3s;
}

.tab-icon {
  font-size: 40rpx;
  opacity: 0.6;
  transition: all 0.3s;
}

.tab-label {
  font-size: 20rpx;
  color: #999999;
  transition: all 0.3s;
}

.tab-item.active .tab-icon {
  opacity: 1;
  transform: scale(1.1);
}

.tab-item.active .tab-label {
  color: #c8a97e;
  font-weight: 600;
}
