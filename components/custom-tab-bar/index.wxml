<view class="tab-bar" style="padding-bottom: {{safeBottom}}px;">
  <view
    wx:for="{{tabs}}"
    wx:key="path"
    class="tab-item {{selected === item.path ? 'active' : ''}}"
    bindtap="switchTab"
    data-path="{{item.path}}"
  >
    <image class="tab-icon" src="{{selected === item.path ? item.activeIcon : item.icon}}" mode="aspectFit" />
    <text class="tab-label">{{item.label}}</text>
  </view>
</view>
