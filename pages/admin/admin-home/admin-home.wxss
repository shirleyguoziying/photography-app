.admin-home { min-height: 100vh; background: #f8f9fa; padding-bottom: 120rpx; }

.greeting-bar {
  background: linear-gradient(135deg, #ffd4e5 0%, #ffb6c1 100%);
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.greeting-text { font-size: 36rpx; font-weight: 700; color: #5a3f4a; display: block; }
.greeting-date { font-size: 24rpx; color: #8b6b7a; display: block; margin-top: 4rpx; }

.header-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; }

.subscribe-btn, .openid-btn {
  border-radius: 9999rpx;
  padding: 10rpx 18rpx;
  font-size: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.subscribe-btn {
  background: rgba(255,255,255,0.7);
  border: 1rpx solid rgba(255,182,193,0.8);
  color: #e08fa8;
}

.openid-btn {
  background: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.8);
  color: #b08b8b;
}

.pending-num { color: #ff9f43; }

.booking-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,182,193,0.15);
}

.row-hover { transform: scale(0.98); }
.row-time { font-size: 30rpx; font-weight: 700; color: #ff8fab; min-width: 80rpx; flex-shrink: 0; }
.row-date-block { display: flex; flex-direction: column; gap: 2rpx; min-width: 120rpx; flex-shrink: 0; }
.row-date { font-size: 28rpx; font-weight: 700; color: #4a4a4a; }
.row-time-small { font-size: 22rpx; color: #999; }
.row-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.row-client { font-size: 30rpx; font-weight: 600; color: #4a4a4a; }
.row-character { font-size: 24rpx; color: #9b59b6; }
.row-location { font-size: 22rpx; color: #999; }
.row-arrow { font-size: 36rpx; color: #ffd4e5; }

.empty { text-align: center; color: #aaa; font-size: 28rpx; padding: 80rpx 0; }

.stats-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, #fff5f8 0%, #fff 100%);
  padding-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(255,182,193,0.2);
}

.stat-card.accent  { background: linear-gradient(135deg, #ffeaa7 0%, #fdcb6e 100%); }
.stat-card.income-card { background: linear-gradient(135deg, #55efc4 0%, #00b894 100%); }

.stat-num { font-size: 44rpx; font-weight: 700; color: #5a5a5a; }
.stat-num.income-num { font-size: 36rpx; color: #00695c; }
.stat-label { font-size: 22rpx; color: #888; }

.stat-card.accent .stat-num { color: #d68910; }
.stat-card.accent .stat-label { color: #7d6608; }

.shortcut-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 24rpx 0;
}

.shortcut-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(255,182,193,0.15);
}

.shortcut-icon { font-size: 40rpx; }
.shortcut-label { flex: 1; font-size: 24rpx; font-weight: 600; color: #5a5a5a; overflow: hidden; }
.shortcut-arrow { font-size: 32rpx; color: #ffd4e5; }

.section { padding: 24rpx; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #5a5a5a; }
.view-all { font-size: 24rpx; color: #ff8fab; font-weight: 500; }