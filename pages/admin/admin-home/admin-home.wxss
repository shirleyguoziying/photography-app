.admin-home { min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }

.greeting-bar {
  background: #1a1a1a;
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.greeting-text { font-size: 36rpx; font-weight: 700; color: #ffffff; }
.greeting-date { font-size: 24rpx; color: rgba(255,255,255,0.5); }

.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #1a1a1a;
  padding-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-card.accent { background: rgba(200,169,126,0.2); }

.stat-num { font-size: 48rpx; font-weight: 700; color: #ffffff; }
.stat-label { font-size: 22rpx; color: rgba(255,255,255,0.6); }

.section { padding: 24rpx; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 700; color: #1a1a1a; }
.view-all { font-size: 24rpx; color: #c8a97e; }
