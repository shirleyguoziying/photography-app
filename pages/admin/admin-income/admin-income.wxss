.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 60rpx; }

/* ===== 返回按钮 ===== */
.back-bar {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 14rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.back-icon { font-size: 44rpx; color: #1a1a1a; line-height: 1; margin-top: -2rpx; }
.back-text  { font-size: 28rpx; color: #1a1a1a; }

/* ===== 月份导航 ===== */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.nav-btn {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; color: #555;
}
.month-label { font-size: 28rpx; font-weight: 700; color: #1a1a1a; }

/* ===== 总收入卡片 ===== */
.total-card {
  background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.total-label { font-size: 24rpx; color: rgba(255,255,255,0.75); }
.total-amount-row { display: flex; align-items: flex-end; gap: 6rpx; }
.total-unit  { font-size: 32rpx; font-weight: 700; color: #fff; margin-bottom: 6rpx; }
.total-amount { font-size: 72rpx; font-weight: 700; color: #fff; line-height: 1; }
.total-count { font-size: 22rpx; color: rgba(255,255,255,0.65); }

/* ===== 收入列表 ===== */
.list-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #999;
  letter-spacing: 2rpx;
  padding: 0 24rpx 12rpx;
}
.record-list { padding: 0 24rpx; }

.record-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}
.card-hover { opacity: 0.85; }

.record-left { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.record-date { font-size: 28rpx; font-weight: 700; color: #1a1a1a; }
.record-char { font-size: 24rpx; color: #7c3aed; }
.record-location { font-size: 22rpx; color: #999; }
.record-note { font-size: 22rpx; color: #c8a97e; }

.record-right { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; flex-shrink: 0; }
.record-amount { font-size: 36rpx; font-weight: 700; color: #16a34a; }
.record-client { font-size: 22rpx; color: #999; }

/* ===== 柱状图 ===== */
.chart-section {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx 32rpx;
}
.chart-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #999;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 24rpx;
}

.chart-wrap {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 220rpx;   /* max bar height(160) + label area(~60) */
}

.chart-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.chart-amount {
  font-size: 16rpx;
  color: #999;
  text-align: center;
  /* constrain to 2 lines max */
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.chart-bar-wrap {
  display: flex;
  align-items: flex-end;
  height: 160rpx;
}

.chart-bar {
  width: 32rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #d1fae5;
  min-height: 0;
  transition: height 0.3s;
}

.chart-bar-active { background: #16a34a; }

.chart-month-label {
  font-size: 20rpx;
  color: #999;
}

/* ===== 空状态 ===== */
.center-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}
