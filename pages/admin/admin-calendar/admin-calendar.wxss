/* 让页面填满视口高度 */
page { height: 100%; }

.cal-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #fff;
  position: relative;
}

/* ===== 返回按钮 ===== */
.back-bar {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 14rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.back-icon { font-size: 44rpx; color: #1a1a1a; line-height: 1; margin-top: -2rpx; }
.back-text  { font-size: 28rpx; color: #1a1a1a; }

/* ===== 周导航 ===== */
.week-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #555;
}
.week-label { font-size: 26rpx; font-weight: 700; color: #1a1a1a; }

/* ===== 星期标题行 ===== */
.day-header-row {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  border-bottom: 2rpx solid #e0e0e0;
  background: #fafafa;
  flex-shrink: 0;
  padding-bottom: 10rpx;
}
.time-spacer { width: 56rpx; flex-shrink: 0; }

.day-header {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.dh-weekday { font-size: 20rpx; color: #999; }

.dh-num-wrap {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.dh-num { font-size: 26rpx; font-weight: 700; color: #1a1a1a; }
.dh-today { background: #1a1a1a; }
.dh-today .dh-num { color: #fff; }

/* ===== 可滚动区域 ===== */
.grid-scroll { flex: 1; }

.grid-inner {
  display: flex;
  flex-direction: row;
}

/* ===== 时间轴 ===== */
.time-axis {
  width: 56rpx;
  flex-shrink: 0;
}

.time-cell {
  height: 80rpx;
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding-right: 8rpx;
  padding-top: 2rpx;
}

.time-text { font-size: 18rpx; color: #bbb; }

/* ===== 天列 ===== */
.day-col {
  flex: 1;
  position: relative;
  border-left: 1rpx solid #e8e8e8;
  min-width: 0;
}

.hour-row {
  height: 80rpx;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

/* ===== 预约色块 ===== */
.bk-block {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  border-radius: 6rpx;
  padding: 4rpx 6rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.bk-yellow { background: rgba(245, 158, 11, 0.92); }
.bk-green  { background: rgba(22, 163, 74, 0.88); }
.bk-gray   { background: rgba(156, 163, 175, 0.78); }

.bk-name {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bk-dur {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.88);
  display: block;
}

/* ===== 图例 ===== */
.legend-row {
  display: flex;
  gap: 32rpx;
  justify-content: center;
  padding: 12rpx 0 16rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.legend-item { display: flex; align-items: center; gap: 8rpx; }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 4rpx; }
.legend-text { font-size: 22rpx; color: #666; }

/* ===== 加载遮罩 ===== */
.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.75);
}
.loading-text { font-size: 28rpx; color: #999; }
