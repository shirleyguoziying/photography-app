<view class="cal-page">

  <!-- 返回按钮 -->
  <view class="back-bar" bindtap="goBack">
    <text class="back-icon">‹</text>
    <text class="back-text">返回工作台</text>
  </view>

  <!-- 周导航 -->
  <view class="week-nav">
    <view class="nav-btn" bindtap="prevWeek">‹</view>
    <text class="week-label">{{weekLabel}}</text>
    <view class="nav-btn" bindtap="nextWeek">›</view>
  </view>

  <!-- 星期标题行（与时间轴对齐） -->
  <view class="day-header-row">
    <view class="time-spacer" />
    <view
      wx:for="{{weekDays}}"
      wx:key="date"
      wx:for-item="day"
      class="day-header"
    >
      <text class="dh-weekday">{{day.weekday}}</text>
      <view class="dh-num-wrap {{day.isToday ? 'dh-today' : ''}}">
        <text class="dh-num">{{day.day}}</text>
      </view>
    </view>
  </view>

  <!-- 可滚动时间轴区域 -->
  <scroll-view scroll-y class="grid-scroll" style="height:{{gridHeight}}rpx;">
    <view class="grid-inner">

      <!-- 左侧时间轴 -->
      <view class="time-axis">
        <view
          wx:for="{{hours}}"
          wx:key="*this"
          wx:for-item="h"
          class="time-cell"
        >
          <text class="time-text">{{h}}</text>
        </view>
        <!-- 末尾时间标签 22:00 -->
        <view class="time-cell"><text class="time-text">22</text></view>
      </view>

      <!-- 7 列天列 -->
      <view
        wx:for="{{weekDays}}"
        wx:key="date"
        wx:for-item="day"
        class="day-col"
      >
        <!-- 网格背景（每小时一格） -->
        <view
          wx:for="{{hours}}"
          wx:key="*this"
          wx:for-item="hr"
          class="hour-row"
        />

        <!-- 预约色块 -->
        <view
          wx:for="{{day.bookings}}"
          wx:key="orderId"
          wx:for-item="bk"
          class="bk-block bk-{{bk.dotColor}}"
          style="top:{{bk.topRpx}}rpx;height:{{bk.heightRpx}}rpx;"
          catchtap="onBlockTap"
          data-id="{{bk.orderId}}"
        >
          <text class="bk-name">{{bk.characterName || bk.clientName}}</text>
          <text class="bk-dur" wx:if="{{bk.heightRpx >= 60}}">{{bk.duration}}h</text>
        </view>
      </view>

    </view>
  </scroll-view>

  <!-- 图例 -->
  <view class="legend-row">
    <view class="legend-item"><view class="legend-dot bk-yellow" /><text class="legend-text">待确认</text></view>
    <view class="legend-item"><view class="legend-dot bk-green" /><text class="legend-text">已确认</text></view>
    <view class="legend-item"><view class="legend-dot bk-gray" /><text class="legend-text">已完成</text></view>
  </view>

  <!-- 加载遮罩 -->
  <view wx:if="{{isLoading}}" class="loading-mask">
    <text class="loading-text">加载中...</text>
  </view>

</view>
