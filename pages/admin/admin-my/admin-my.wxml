<view class="admin-my-page">
  <view class="user-card">
    <view class="user-info">
      <text class="user-name">摄影师后台</text>
      <text class="user-role">管理员</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="goToPortfolio">
      <text class="menu-icon">🖼️</text>
      <text class="menu-label">作品集管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToProps">
      <text class="menu-icon">🎁</text>
      <text class="menu-label">道具管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToDelivery">
      <text class="menu-icon">📦</text>
      <text class="menu-label">交付管理</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="goToCalendar">
      <text class="menu-icon">📅</text>
      <text class="menu-label">日历排期</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToIncome">
      <text class="menu-icon">💰</text>
      <text class="menu-label">收入统计</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-section">
    <button class="btn btn-outline logout-btn" bindtap="toggleRole">切换为普通用户</button>
  </view>

  <!-- 底部导航栏 -->
  <custom-tab-bar />
</view>