.delivery-page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; padding-bottom: 180rpx; }

.upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  border: 3rpx dashed #e8e8e8;
  padding: 80rpx 40rpx;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.upload-icon { font-size: 80rpx; }
.upload-title { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.upload-hint { font-size: 24rpx; color: #999999; }

.progress-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.progress-fill {
  height: 8rpx;
  background: #c8a97e;
  border-radius: 4rpx;
  transition: width 0.3s;
  margin-bottom: 12rpx;
}

.progress-text { font-size: 24rpx; color: #666666; }

.uploaded-grid { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.grid-header { margin-bottom: 20rpx; }
.grid-count { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }

.photo-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8rpx; }
.photo-thumb-wrap { aspect-ratio: 1; border-radius: 8rpx; overflow: hidden; }
.photo-thumb { width: 100%; height: 100%; }

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.bottom-actions .btn { flex: 1; }
