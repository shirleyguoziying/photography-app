<view class="page">

  <!-- 返回 -->
  <view class="back-bar" bindtap="goBack">
    <text class="back-icon">‹</text>
    <text class="back-text">返回订单</text>
  </view>

  <!-- 订单信息 -->
  <view class="booking-bar" wx:if="{{bookingInfo}}">
    <view class="booking-meta">
      <text class="booking-date">{{bookingInfo.preferredDate}}</text>
      <text class="booking-client">{{bookingInfo.clientName}}</text>
      <text class="booking-char" wx:if="{{bookingInfo.characterName}}"> · 🎭 {{bookingInfo.characterName}}</text>
    </view>
    <view class="count-pills">
      <text class="pill pill-total">{{photos.length}} 张</text>
      <text class="pill pill-star">⭐ {{highlightCount}}</text>
    </view>
  </view>

  <!-- 上传按钮 + 进度 -->
  <view class="upload-row">
    <view class="upload-btn {{uploading ? 'uploading' : ''}}" bindtap="chooseAndUpload">
      <text class="upload-icon">＋</text>
      <text class="upload-label">{{uploading ? '上传中 ' + uploadProgress : '添加照片'}}</text>
    </view>
    <text class="upload-hint">点击⭐标记优质返图，标记后将展示给客户</text>
  </view>

  <!-- 照片网格 -->
  <view class="photo-grid" wx:if="{{photos.length > 0}}">
    <view
      wx:for="{{photos}}"
      wx:key="_id"
      class="photo-cell"
    >
      <!-- 缩略图 -->
      <image
        class="photo-img"
        src="{{item.fileId}}"
        mode="aspectFill"
        bindtap="previewPhoto"
        data-index="{{index}}"
      />
      <!-- 优质标记 -->
      <view
        class="star-btn {{item.isHighlight ? 'star-on' : 'star-off'}}"
        catchtap="toggleHighlight"
        data-id="{{item._id}}"
        data-flag="{{item.isHighlight}}"
      >
        <text>⭐</text>
      </view>
      <!-- 删除 -->
      <view
        class="del-btn"
        catchtap="deletePhoto"
        data-id="{{item._id}}"
        data-file-id="{{item.fileId}}"
      >
        <text class="del-icon">✕</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!uploading}}" class="empty-tip">
    <text>暂无返图，点击上方添加照片</text>
  </view>

</view>
