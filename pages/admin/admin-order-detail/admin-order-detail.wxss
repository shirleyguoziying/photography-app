.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 180rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.status-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-id { font-size: 22rpx; color: #999999; }

.section-card { background: #fff; border-radius: 16rpx; padding: 28rpx; }
.section-title { font-size: 28rpx; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 20rpx; }

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 16rpx;
}

.detail-row:last-child { border-bottom: none; }
.dl { font-size: 26rpx; color: #999999; flex-shrink: 0; width: 120rpx; }
.dr { font-size: 26rpx; color: #1a1a1a; flex: 1; text-align: right; }

.action-group {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.action-group .btn { flex: 1; }
