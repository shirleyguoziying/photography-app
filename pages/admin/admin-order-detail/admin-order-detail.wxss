.back-bar {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 14rpx 24rpx;
  background: #f5f5f5;
}
.back-icon { font-size: 44rpx; color: #1a1a1a; line-height: 1; margin-top: -2rpx; }
.back-text  { font-size: 28rpx; color: #1a1a1a; }

.center-tip { display: flex; align-items: center; justify-content: center; height: 60vh; color: #999; font-size: 28rpx; }

.detail-page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; padding-bottom: 200rpx; display: flex; flex-direction: column; gap: 20rpx; }

/* 状态卡 */
.status-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-pill {
  font-size: 26rpx;
  font-weight: 700;
  padding: 8rpx 24rpx;
  border-radius: 9999rpx;
}

.status-pill.status-pending    { background: #fef3c7; color: #d97706; }
.status-pill.status-confirmed  { background: #d1fae5; color: #059669; }
.status-pill.status-completed  { background: #f3f4f6; color: #374151; }
.status-pill.status-cancelled  { background: #fee2e2; color: #dc2626; }

.booking-id { font-size: 22rpx; color: #bbbbbb; font-family: monospace; }

/* 信息卡 */
.section-card { background: #fff; border-radius: 20rpx; padding: 28rpx; }
.section-title { font-size: 22rpx; font-weight: 700; color: #c8a97e; letter-spacing: 2rpx; display: block; margin-bottom: 20rpx; }

.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-row:last-child { border-bottom: none; }

.dl { font-size: 26rpx; color: #999999; flex-shrink: 0; min-width: 120rpx; }
.dr { font-size: 26rpx; color: #1a1a1a; flex: 1; text-align: right; }
.dr.accent { color: #7c3aed; font-weight: 600; }
.dr-col { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; flex: 1; }
.dr-sub { font-size: 22rpx; color: #999999; }

/* 角色参考图横向滚动 */
.ref-section { margin-top: 16rpx; }
.ref-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 12rpx; }

.ref-scroll { white-space: nowrap; }
.ref-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; margin-right: 12rpx; display: inline-block; }

/* 道具 chips */
.prop-row { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 4rpx 0 8rpx; }

.prop-chip {
  display: flex; align-items: center; gap: 10rpx;
  background: #f8f8f8; border-radius: 9999rpx;
  padding: 8rpx 20rpx 8rpx 8rpx;
  border: 1rpx solid #e8e8e8;
}

.prop-chip-img { width: 48rpx; height: 48rpx; border-radius: 50%; }
.prop-chip-name { font-size: 26rpx; color: #1a1a1a; }
.props-notes { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }

/* 颜色显示 */
.color-display { display: flex; align-items: center; gap: 14rpx; flex: 1; justify-content: flex-end; }
.color-swatch { width: 48rpx; height: 48rpx; border-radius: 10rpx; border: 1rpx solid rgba(0,0,0,0.1); flex-shrink: 0; }
.color-hex { font-size: 26rpx; font-weight: 700; color: #1a1a1a; font-family: monospace; }
.color-rgb { font-size: 20rpx; color: #999999; }

/* 备注区 */
.note-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.note-edit-btn { font-size: 24rpx; color: #c8a97e; padding: 4rpx 0; }
.note-content { font-size: 26rpx; color: #333; line-height: 1.7; }
.note-empty { font-size: 26rpx; color: #ccc; }

.note-input-area { display: flex; flex-direction: column; gap: 16rpx; }

.note-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #1a1a1a;
  line-height: 1.6;
  border: 1rpx solid #e8e8e8;
  box-sizing: border-box;
}

.note-save-btn {
  background: #1a1a1a;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.note-save-hover { opacity: 0.65; }

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  border: none;
  border-radius: 16rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-confirm  { background: #059669; color: #fff; }
.btn-complete { background: #1a1a1a; color: #fff; }
.btn-cancel   { background: #fee2e2; color: #dc2626; }
.btn-hover    { opacity: 0.7; }

.action-done {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #999999;
}

/* ===== 收入显示 ===== */
.income-display { display: flex; flex-direction: column; gap: 8rpx; padding: 4rpx 0; }
.income-amount-text { font-size: 40rpx; font-weight: 700; color: #16a34a; }
.income-note-text { font-size: 24rpx; color: #999; }

/* ===== 收入录入底部弹窗 ===== */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
}

.income-sheet {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 201;
  padding: 0 32rpx env(safe-area-inset-bottom);
}

.income-sheet-handle {
  width: 64rpx; height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin: 20rpx auto 24rpx;
}

.income-sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
}

.income-field {
  margin-bottom: 24rpx;
}

.income-field-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.income-input-wrap {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e8e8;
}

.income-prefix {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-right: 8rpx;
}

.income-input {
  flex: 1;
  height: 88rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  background: transparent;
}

.income-input-note {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e8e8;
  font-size: 28rpx;
  font-weight: 400;
  height: 80rpx;
  color: #333;
}

.income-sheet-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
  padding-bottom: 32rpx;
}

.income-skip-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 16rpx;
}

.income-skip-btn::after { border: none; }

.income-save-btn {
  flex: 2;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: #16a34a;
  color: #fff;
  border: none;
  border-radius: 16rpx;
}

.income-save-btn::after { border: none; }
.income-save-hover { opacity: 0.75; }

/* ===== 返图管理入口 ===== */
.delivery-entry {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  gap: 16rpx;
}
.delivery-entry-icon { font-size: 36rpx; }
.delivery-entry-label { flex: 1; font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.delivery-entry-arrow { font-size: 36rpx; color: #ccc; }
