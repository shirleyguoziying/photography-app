<view class="admin-banners">
  <view class="header-section">
    <view class="tip-card">
      <text class="tip-icon">💡</text>
      <view class="tip-content">
        <text class="tip-title">轮播图尺寸建议</text>
        <text class="tip-text">推荐尺寸：750×400像素（比例约1.875:1）</text>
        <text class="tip-text">支持JPG、PNG格式，文件大小不超过5MB</text>
      </view>
    </view>
  </view>

  <view class="add-section">
    <view class="add-btn" bindtap="showAddModal">
      <text class="add-icon">+</text>
      <text>添加轮播图</text>
    </view>
  </view>

  <view class="banners-list">
    <view class="section-header">
      <text class="section-title">轮播图列表</text>
      <text class="section-tip">拖拽可调整顺序</text>
    </view>

    <view wx:if="{{loading}}" class="loading-tip">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{banners.length === 0}}" class="empty-state">
      <text class="empty-icon">🖼️</text>
      <text class="empty-text">暂无轮播图</text>
      <text class="empty-sub">点击上方按钮添加第一个轮播图</text>
    </view>

    <view wx:else class="banners-container">
      <view 
        wx:for="{{banners}}" 
        wx:key="_id"
        class="banner-card"
        data-index="{{index}}"
      >
        <view class="banner-preview">
          <image class="banner-img" src="{{item.imageUrl}}" mode="aspectFill" />
        </view>
        <view class="banner-info">
          <view class="banner-title">{{item.title || '无标题'}}</view>
          <view class="banner-subtitle">{{item.subtitle || '无副标题'}}</view>
          <view class="banner-actions">
            <view class="action-btn edit-btn" bindtap="editBanner" data-item="{{item}}">
              编辑
            </view>
            <view class="action-btn delete-btn" bindtap="deleteBanner" data-id="{{item._id}}">
              删除
            </view>
          </view>
        </view>
        <view class="sort-handle">⋮⋮</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showModal}}" class="modal-mask" bindtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{editingBanner ? '编辑轮播图' : '添加轮播图'}}</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">上传图片</text>
          <view class="upload-area" bindtap="chooseImage">
            <image wx:if="{{tempImageUrl}}" class="upload-preview" src="{{tempImageUrl}}" mode="aspectFill" />
            <view wx:else class="upload-placeholder">
              <text class="upload-icon">📷</text>
              <text class="upload-text">点击上传图片</text>
            </view>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">标题（可选）</text>
          <input class="form-input" placeholder="输入标题" value="{{formData.title}}" bindinput="onTitleInput" />
        </view>
        <view class="form-item">
          <text class="form-label">副标题（可选）</text>
          <input class="form-input" placeholder="输入副标题" value="{{formData.subtitle}}" bindinput="onSubtitleInput" />
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel-btn" bindtap="hideModal">取消</view>
        <view class="modal-btn confirm-btn" bindtap="saveBanner" disabled="{{!tempImageUrl && !editingBanner}}">
          保存
        </view>
      </view>
    </view>
  </view>
</view>
