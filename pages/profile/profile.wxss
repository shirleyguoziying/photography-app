.profile-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.user-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.nickname { font-size: 32rpx; font-weight: 700; color: #1a1a1a; }
.phone { font-size: 24rpx; color: #999999; }

.edit-btn {
  font-size: 24rpx;
  color: #c8a97e;
  padding: 8rpx 20rpx;
  border: 1rpx solid #c8a97e;
  border-radius: 9999rpx;
}

.menu-group {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 24rpx 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child { border-bottom: none; }

.menu-icon { font-size: 36rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: #1a1a1a; }
.menu-arrow { font-size: 36rpx; color: #cccccc; }

.logout-section { padding: 24rpx; }
.logout-btn { width: 100%; color: #ff4d4f; border-color: #ff4d4f; }
