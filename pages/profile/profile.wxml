<view class="profile-page">
  <view class="user-card">
    <image class="avatar" src="{{user.avatarUrl || '/assets/images/placeholder-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="nickname">{{user.nickname || '用户'}}</text>
      <text class="phone">{{user.phone || '未绑定手机'}}</text>
    </view>
    <view class="edit-btn" bindtap="editProfile">编辑</view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="goToOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-label">我的订单</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="bindPhone" wx:if="{{!user.phone}}">
      <text class="menu-icon">📱</text>
      <text class="menu-label">绑定手机号</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="openAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="openPrivacy">
      <text class="menu-icon">🔒</text>
      <text class="menu-label">隐私政策</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-section">
    <button class="btn btn-outline dev-btn" bindtap="toggleRole">切换为摄影师</button>
    <button class="btn btn-outline logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
