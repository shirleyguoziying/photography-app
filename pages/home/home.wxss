.home-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* Banner Section */
.banner-section {
  width: 100%;
  height: 360rpx;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  position: relative;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.banner-icon {
  font-size: 80rpx;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* Welcome Section */
.welcome-section {
  padding: 24rpx;
}

.welcome-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
}

.welcome-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.welcome-sub {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

/* Quick Actions */
.quick-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 24rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  transition: all 0.3s;
}

.action-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.action-book {
  background: linear-gradient(135deg, #fff7e6, #ffe8b8);
}

.action-orders {
  background: linear-gradient(135deg, #e6f7ff, #b8d4ff);
}

.action-gallery {
  background: linear-gradient(135deg, #f6ffed, #d4ffb8);
}

.action-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* Portfolio Section */
.portfolio-section {
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.section-more {
  font-size: 24rpx;
  color: #c8a97e;
}

.loading-tip,
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 24rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: calc((100% - 16rpx) / 2);
  aspect-ratio: 3/4;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.photo-role {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
}

/* Waterfall Section */
.waterfall-section {
  padding: 24rpx;
  margin-top: 24rpx;
}

.waterfall-container {
  display: flex;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.waterfall-item {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.waterfall-img {
  width: 100%;
  display: block;
}

.waterfall-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.waterfall-role {
  font-size: 20rpx;
  color: #ffffff;
}

.featured-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
  color: #ffffff;
  background: #c8a97e;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
  font-weight: 600;
}
