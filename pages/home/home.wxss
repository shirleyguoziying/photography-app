.hero-banner {
  height: 480rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #3d3d3d 100%);
  display: flex;
  align-items: flex-end;
  padding: 48rpx;
  position: relative;
  overflow: hidden;
}

.hero-content { display: flex; flex-direction: column; gap: 12rpx; }

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
}

.hero-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 8rpx;
}

.btn-book {
  width: 240rpx;
  height: 72rpx;
  background: #c8a97e;
  color: #ffffff;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 72rpx;
}

.btn-book::after { border: none; }

.style-filter {
  background: #ffffff;
  padding: 0 24rpx;
  white-space: nowrap;
}

.filter-list {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  align-items: center;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 9999rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 26rpx;
  color: #666666;
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-chip.active {
  background: #1a1a1a;
  border-color: #1a1a1a;
  color: #ffffff;
}

.section { padding: 32rpx 24rpx; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.photo-masonry {
  display: flex;
  gap: 16rpx;
}

.masonry-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 26rpx;
}
