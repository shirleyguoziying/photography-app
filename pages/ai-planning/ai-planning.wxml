<view class="ai-page">
  <!-- Loading State -->
  <view wx:if="{{isLoading}}" class="loading-state">
    <view class="ai-loader">✨</view>
    <text class="loading-title">AI 正在生成拍摄策划...</text>
    <text class="loading-sub">根据您的预约信息分析最优方案</text>
  </view>

  <!-- Plan Content -->
  <view wx:elif="{{plan}}" class="plan-content">
    <view class="plan-header">
      <view class="plan-badge">AI 生成策划</view>
      <text class="plan-title">拍摄方案</text>
      <text class="plan-sub">共 {{plan.scenes.length}} 个场景 · {{plan.timeline.length}} 个时间节点</text>
    </view>

    <!-- Scenes -->
    <view class="section">
      <text class="section-title">场景规划</text>
      <view class="scene-list">
        <view wx:for="{{plan.scenes}}" wx:key="index" class="scene-card">
          <view class="scene-header">
            <view class="scene-num">{{item.index}}</view>
            <text class="scene-title">{{item.title}}</text>
          </view>
          <view class="scene-row"><text class="sl">地点</text><text class="sv">{{item.location}}</text></view>
          <view class="scene-row"><text class="sl">时间</text><text class="sv">{{item.time}}</text></view>
          <view class="scene-row"><text class="sl">光线</text><text class="sv">{{item.lighting}}</text></view>
          <view class="scene-row" wx:if="{{item.notes}}"><text class="sl">备注</text><text class="sv">{{item.notes}}</text></view>
          <view class="pose-list" wx:if="{{item.poses}}">
            <text class="sl">建议姿势</text>
            <view class="pose-chips">
              <text wx:for="{{item.poses}}" wx:key="*this" wx:for-item="pose" class="pose-chip">{{pose}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Timeline -->
    <view class="section">
      <text class="section-title">时间轴</text>
      <view class="timeline">
        <view wx:for="{{plan.timeline}}" wx:key="index" class="timeline-item">
          <view class="tl-dot" />
          <view class="tl-content">
            <text class="tl-time">{{item.time}}</text>
            <text class="tl-task">{{item.task}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Tips -->
    <view class="section">
      <text class="section-title">拍摄建议</text>
      <view class="tips-list">
        <view wx:for="{{plan.tips}}" wx:key="index" class="tip-item">
          <text class="tip-dot">·</text>
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="regenerate-btn" bindtap="regenerate">
      <text>重新生成策划</text>
    </view>
  </view>
</view>
