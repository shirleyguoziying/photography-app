.ai-page { min-height: 100vh; background: #0a0a0a; }

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  gap: 24rpx;
}

.ai-loader { font-size: 100rpx; animation: pulse 1.5s infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
.loading-title { font-size: 32rpx; font-weight: 600; color: #ffffff; }
.loading-sub { font-size: 26rpx; color: rgba(255,255,255,0.5); }

.plan-content { padding-bottom: 80rpx; }

.plan-header {
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #1a1a1a, #2d2d2d);
}

.plan-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(200,169,126,0.2);
  color: #c8a97e;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  margin-bottom: 16rpx;
}

.plan-title { font-size: 44rpx; font-weight: 700; color: #ffffff; display: block; }
.plan-sub { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 8rpx; }

.section { padding: 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.section-title { font-size: 28rpx; font-weight: 700; color: #c8a97e; display: block; margin-bottom: 24rpx; }

.scene-list { display: flex; flex-direction: column; gap: 20rpx; }

.scene-card {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.scene-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.scene-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #c8a97e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  flex-shrink: 0;
}

.scene-title { font-size: 28rpx; font-weight: 600; color: #ffffff; }
.scene-row { display: flex; gap: 16rpx; padding: 8rpx 0; }
.sl { font-size: 22rpx; color: rgba(255,255,255,0.4); width: 60rpx; flex-shrink: 0; }
.sv { font-size: 22rpx; color: rgba(255,255,255,0.8); flex: 1; }

.pose-list { padding-top: 8rpx; }
.pose-chips { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 8rpx; }
.pose-chip { font-size: 20rpx; color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.08); padding: 6rpx 16rpx; border-radius: 9999rpx; }

.timeline { display: flex; flex-direction: column; gap: 0; }

.timeline-item {
  display: flex;
  gap: 20rpx;
  position: relative;
  padding-bottom: 24rpx;
}

.timeline-item:last-child { padding-bottom: 0; }

.tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c8a97e;
  flex-shrink: 0;
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
}

.timeline-item:not(:last-child) .tl-dot::after {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 7rpx;
  width: 2rpx;
  height: calc(100% + 24rpx);
  background: rgba(200,169,126,0.3);
}

.tl-content { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.tl-time { font-size: 22rpx; color: #c8a97e; font-weight: 600; }
.tl-task { font-size: 26rpx; color: rgba(255,255,255,0.8); }

.tips-list { display: flex; flex-direction: column; gap: 16rpx; }
.tip-item { display: flex; gap: 12rpx; }
.tip-dot { color: #c8a97e; font-size: 28rpx; flex-shrink: 0; }
.tip-text { font-size: 26rpx; color: rgba(255,255,255,0.7); line-height: 1.6; flex: 1; }

.regenerate-btn {
  margin: 32rpx;
  padding: 24rpx;
  text-align: center;
  border: 2rpx solid rgba(200,169,126,0.4);
  border-radius: 16rpx;
  color: #c8a97e;
  font-size: 28rpx;
}
