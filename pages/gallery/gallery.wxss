.gallery-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.page-header {
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.page-sub {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.loading-tip,
.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 24rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: calc((100% - 16rpx) / 2);
  aspect-ratio: 3/4;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.photo-role {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
}
