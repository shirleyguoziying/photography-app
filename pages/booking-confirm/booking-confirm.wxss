.confirm-page { min-height: 100vh; background: #f5f5f5; padding-bottom: 160rpx; }

.summary-header { padding: 40rpx 32rpx 24rpx; }
.summary-title { font-size: 40rpx; font-weight: 700; color: #1a1a1a; }

/* 卡片 */
.section-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx 20rpx;
  padding: 28rpx 28rpx 16rpx;
}

.section-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #c8a97e;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

/* 行 */
.confirm-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.confirm-row:last-child { border-bottom: none; }

.confirm-col {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 14rpx 0;
}

.label { font-size: 26rpx; color: #999999; flex-shrink: 0; min-width: 140rpx; }
.value { font-size: 28rpx; color: #1a1a1a; text-align: right; flex: 1; }
.value.accent { color: #c8a97e; font-weight: 600; }
.value-col { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; flex: 1; }
.value-sub { font-size: 22rpx; color: #999999; text-align: right; }

/* 参考图缩略图网格 */
.thumb-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.thumb { width: 120rpx; height: 120rpx; border-radius: 12rpx; }

/* 道具 chip */
.prop-row { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 8rpx 0 4rpx; }

.prop-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #f8f8f8;
  border-radius: 9999rpx;
  padding: 8rpx 20rpx 8rpx 8rpx;
  border: 1rpx solid #e8e8e8;
}

.prop-chip-img { width: 48rpx; height: 48rpx; border-radius: 50%; }
.prop-chip-name { font-size: 26rpx; color: #1a1a1a; }

/* 颜色展示 */
.color-display {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  justify-content: flex-end;
}

.color-swatch {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(0,0,0,0.1);
  flex-shrink: 0;
}

.color-hex { font-size: 26rpx; font-weight: 700; color: #1a1a1a; font-family: monospace; }
.color-rgb { font-size: 20rpx; color: #999999; }

/* AI 入口 */
.ai-planning-teaser {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #1a1a1a, #3d3d3d);
  border-radius: 20rpx;
  margin: 0 24rpx 20rpx;
  padding: 28rpx 24rpx;
}

.ai-icon { font-size: 40rpx; }
.ai-text { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.ai-title { font-size: 28rpx; font-weight: 700; color: #ffffff; }
.ai-sub { font-size: 22rpx; color: rgba(255,255,255,0.6); }
.arrow { font-size: 36rpx; color: rgba(255,255,255,0.5); }

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.btn { flex: 1; border-radius: 16rpx; height: 96rpx; line-height: 96rpx; font-size: 30rpx; font-weight: 600; border: none; }
.btn-primary { background: #1a1a1a; color: #ffffff; }
.btn-outline { background: #ffffff; color: #666; border: 2rpx solid #d0d0d0; }
.btn-hover-primary { opacity: 0.65; }
.btn-hover-outline { background: #f5f5f5; }

.loading-placeholder { display: flex; align-items: center; justify-content: center; height: 100vh; color: #999; font-size: 28rpx; }
