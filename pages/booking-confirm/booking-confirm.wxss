.confirm-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 180rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-header { padding: 16rpx 0; }
.summary-title { font-size: 36rpx; font-weight: 700; color: #1a1a1a; }

.section-card { background: #fff; border-radius: 16rpx; padding: 8rpx 28rpx; }

.confirm-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 16rpx;
}

.confirm-row:last-child { border-bottom: none; }

.label { font-size: 26rpx; color: #999999; flex-shrink: 0; width: 140rpx; }
.value { font-size: 28rpx; color: #1a1a1a; text-align: right; flex: 1; }
.value.accent { color: #c8a97e; font-weight: 600; }
.value-col { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }
.value-sub { font-size: 22rpx; color: #999999; }

.ai-planning-teaser {
  background: linear-gradient(135deg, #1a1a1a, #3d3d3d);
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ai-icon { font-size: 44rpx; }
.ai-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.ai-title { font-size: 28rpx; font-weight: 600; color: #ffffff; }
.ai-sub { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.arrow { color: rgba(255,255,255,0.4); font-size: 36rpx; }

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.bottom-actions .btn { flex: 1; }
