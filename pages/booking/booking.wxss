.booking-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.step-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.section-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.field-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1a1a1a;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-value.placeholder { color: #999999; }
.arrow { font-size: 36rpx; color: #cccccc; }

.time-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }

.time-chip {
  padding: 12rpx 28rpx;
  border-radius: 9999rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 26rpx;
  color: #666666;
}

.time-chip.active { border-color: #1a1a1a; background: #1a1a1a; color: #ffffff; }
.time-chip.disabled { opacity: 0.4; }

.duration-list { display: flex; flex-direction: column; gap: 12rpx; }

.duration-item {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 28rpx;
  color: #666666;
}

.duration-item.active { border-color: #1a1a1a; background: #f8f8f8; color: #1a1a1a; font-weight: 600; }

.location-map-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 8rpx;
}

.map-btn-icon { font-size: 32rpx; }
.map-btn-text { flex: 1; font-size: 28rpx; color: #1a1a1a; }

.map-result {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #f0f9f4;
  border-radius: 12rpx;
  border-left: 6rpx solid #10b981;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.map-result-name { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.map-result-addr { font-size: 24rpx; color: #666666; }
.map-clear { font-size: 22rpx; color: #999999; margin-top: 8rpx; }

.divider-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 28rpx 0 24rpx;
}

.divider-line { flex: 1; height: 1rpx; background: #e8e8e8; }
.divider-text { font-size: 22rpx; color: #bbbbbb; white-space: nowrap; }

.text-input {
  display: block;
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  background: #f8f8f8;
  box-sizing: border-box;
}

.mini-map { width: 100%; height: 300rpx; border-radius: 12rpx; overflow: hidden; }

.textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 26rpx;
  color: #1a1a1a;
  line-height: 1.6;
  background: #f8f8f8;
  padding: 16rpx;
  border-radius: 8rpx;
  border: none;
  box-sizing: border-box;
}

.radio-group { display: flex; gap: 16rpx; }

.radio-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 28rpx;
  color: #666666;
}

.radio-item.active { border-color: #1a1a1a; background: #1a1a1a; color: #ffffff; }

.count-stepper {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.stepper-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1a1a1a;
}

.stepper-val { font-size: 36rpx; font-weight: 700; color: #1a1a1a; min-width: 48rpx; text-align: center; }

/* ===== Step 3: 拍摄偏好卡片 ===== */
.pref-list { display: flex; flex-direction: column; gap: 16rpx; margin-top: 8rpx; }

.pref-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e8e8e8;
  background: #fafafa;
  transition: border-color 0.15s, background 0.15s;
}

.pref-card.pref-selected {
  border-color: #c8a97e;
  background: #fdf8f2;
}

.pref-hover { opacity: 0.75; }

.pref-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #d0d0d0;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pref-card.pref-selected .pref-radio { border-color: #c8a97e; }

.pref-radio-inner {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #c8a97e;
}

.pref-text { display: flex; flex-direction: column; gap: 6rpx; flex: 1; }
.pref-title { font-size: 28rpx; font-weight: 700; color: #1a1a1a; }
.pref-desc { font-size: 24rpx; color: #888888; line-height: 1.5; }

/* ===== Step 3: RGB 色调选择器 ===== */
.color-preview-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0 28rpx;
}

.color-swatch {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(0,0,0,0.08);
  flex-shrink: 0;
}

.color-hex {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.color-rgb-label { font-size: 22rpx; color: #999999; }

.slider-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.slider-label {
  font-size: 26rpx;
  font-weight: 700;
  width: 32rpx;
  text-align: center;
  flex-shrink: 0;
}

.slider-r { color: #ef4444; }
.slider-g { color: #22c55e; }
.slider-b { color: #3b82f6; }

.rgb-slider { flex: 1; }

.slider-val {
  font-size: 24rpx;
  color: #666666;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

/* 必填标记 & 提示 */
.required-mark { color: #ef4444; font-size: 26rpx; margin-left: 4rpx; }
.field-hint { color: #bbbbbb; font-size: 22rpx; font-weight: 400; margin-left: 12rpx; }

/* 参考图网格 */
.ref-image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.ref-image-item { position: relative; aspect-ratio: 1; border-radius: 12rpx; overflow: hidden; }
.ref-image { width: 100%; height: 100%; }
.ref-image-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.55);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ref-image-add {
  aspect-ratio: 1;
  border-radius: 12rpx;
  border: 2rpx dashed #d0d0d0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fafafa;
}

.ref-image-add.uploading { opacity: 0.6; }
.add-icon { font-size: 48rpx; color: #c8a97e; line-height: 1; }
.add-label { font-size: 22rpx; color: #999999; }

/* 上传加载动画 */
.upload-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #c8a97e;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* 道具列表 */
.props-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}

.prop-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  padding: 24rpx;
  background: #fff;
  transition: all 0.2s ease;
}

.prop-item.selected {
  border-color: #c8a97e;
  border-width: 4rpx;
  background: #fdf8f2;
}

.prop-check-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  border: 3rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.prop-check-box.checked {
  background: #c8a97e;
  border-color: #c8a97e;
}

.prop-check-box text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.prop-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.prop-name-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.prop-desc-text {
  font-size: 24rpx;
  color: #999999;
}

/* 已选道具展示 */
.selected-props {
  margin-top: 24rpx;
  background: #fdf8f2;
  border-radius: 16rpx;
  padding: 20rpx;
}

.selected-props-header {
  margin-bottom: 16rpx;
}

.selected-props-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #c8a97e;
}

.selected-props-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.selected-prop-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #fff;
  border-radius: 8rpx;
  border-left: 6rpx solid #c8a97e;
}

.selected-prop-name {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.prop-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
}

.prop-check {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #c8a97e 0%, #b8956a 100%);
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(200, 169, 126, 0.5);
  z-index: 10;
  animation: checkPop 0.3s ease;
}

@keyframes checkPop {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); opacity: 1; }
}

.prop-name { font-size: 24rpx; color: #1a1a1a; font-weight: 600; text-align: center; }
.prop-desc { font-size: 20rpx; color: #999999; text-align: center; line-height: 1.4; }

.props-loading { text-align: center; color: #999; font-size: 26rpx; padding: 32rpx 0; }
.props-empty {
  text-align: center;
  color: #666666;
  font-size: 26rpx;
  padding: 40rpx 0;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-top: 8rpx;
}

/* 按钮状态 */
.bottom-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.bottom-actions .btn { flex: 1; }

/* 主按钮：可点击 */
.btn-primary {
  background: #1a1a1a;
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
}

/* 主按钮：不可用（角色/图片未填时） */
.btn-inactive {
  background: #d0d0d0;
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
}

/* 按下效果 */
.btn-hover-primary { opacity: 0.65; }
.btn-outline { border: 2rpx solid #d0d0d0; color: #666; border-radius: 16rpx; height: 96rpx; line-height: 96rpx; font-size: 30rpx; background: #fff; }
.btn-hover-outline { background: #f5f5f5; }
