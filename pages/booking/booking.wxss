.booking-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.step-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.section-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.field-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1a1a1a;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-value.placeholder { color: #999999; }
.arrow { font-size: 36rpx; color: #cccccc; }

.time-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }

.time-chip {
  padding: 12rpx 28rpx;
  border-radius: 9999rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 26rpx;
  color: #666666;
}

.time-chip.active { border-color: #1a1a1a; background: #1a1a1a; color: #ffffff; }
.time-chip.disabled { opacity: 0.4; }

.duration-list { display: flex; flex-direction: column; gap: 12rpx; }

.duration-item {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 28rpx;
  color: #666666;
}

.duration-item.active { border-color: #1a1a1a; background: #f8f8f8; color: #1a1a1a; font-weight: 600; }

.location-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.location-selected { display: flex; flex-direction: column; gap: 4rpx; }
.location-name { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.location-addr { font-size: 24rpx; color: #999999; }
.location-placeholder { font-size: 28rpx; color: #999999; }

.mini-map { width: 100%; height: 300rpx; border-radius: 12rpx; overflow: hidden; }

.textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 26rpx;
  color: #1a1a1a;
  line-height: 1.6;
  background: #f8f8f8;
  padding: 16rpx;
  border-radius: 8rpx;
  border: none;
  box-sizing: border-box;
}

.radio-group { display: flex; gap: 16rpx; }

.radio-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 28rpx;
  color: #666666;
}

.radio-item.active { border-color: #1a1a1a; background: #1a1a1a; color: #ffffff; }

.count-stepper {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.stepper-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1a1a1a;
}

.stepper-val { font-size: 36rpx; font-weight: 700; color: #1a1a1a; min-width: 48rpx; text-align: center; }

.tag-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }

.tag-chip {
  padding: 12rpx 28rpx;
  border-radius: 9999rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 26rpx;
  color: #666666;
}

.tag-chip.active { border-color: #c8a97e; background: #c8a97e; color: #ffffff; }

.mood-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; }

.mood-item {
  padding: 20rpx 12rpx;
  text-align: center;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  font-size: 26rpx;
  color: #666666;
}

.mood-item.active { border-color: #1a1a1a; background: #1a1a1a; color: #ffffff; }

.bottom-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.bottom-actions .btn { flex: 1; }
