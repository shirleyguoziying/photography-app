.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.cover-area {
  position: relative;
  height: 560rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
}

.photographer-meta {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  flex-shrink: 0;
}

.meta-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.display-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.style-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.style-chip {
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.2);
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
}

.stats-bar {
  background: #ffffff;
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e8e8e8;
}

.bio-card {
  background: #ffffff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.bio-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
}

.section {
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  display: block;
}

.photo-masonry {
  display: flex;
  gap: 16rpx;
}

.masonry-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.book-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.book-btn {
  width: 100%;
}

.loading-page {
  padding: 24rpx;
}
