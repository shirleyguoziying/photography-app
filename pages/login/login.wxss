.login-page {
  min-height: 100vh;
  background: #0a0a0a;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 120rpx 48rpx 80rpx;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  justify-content: center;
  gap: 24rpx;
}

.logo { width: 160rpx; height: 160rpx; }

.brand {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 8rpx;
}

.tagline {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 4rpx;
}

.actions { display: flex; flex-direction: column; gap: 24rpx; }

.btn-wechat {
  width: 100%;
  height: 96rpx;
  background: #c8a97e;
  border-radius: 9999rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
}

.btn-wechat::after { border: none; }

.privacy-tip {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
  line-height: 1.6;
}

.link { color: rgba(200,169,126,0.8); }
