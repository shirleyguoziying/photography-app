.status-tabs {
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  white-space: nowrap;
}

.tab-list {
  display: flex;
  padding: 0 24rpx;
  gap: 8rpx;
}

.tab {
  padding: 24rpx 20rpx;
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
  position: relative;
}

.tab.active {
  color: #1a1a1a;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #1a1a1a;
  border-radius: 2rpx;
}

.order-list { padding: 24rpx; }

.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.client-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-badge.status-pending { background: #fff7e6; color: #d46b08; }
.status-badge.status-confirmed { background: #e6f7ff; color: #0958d9; }
.status-badge.status-completed { background: #f6ffed; color: #389e0d; }
.status-badge.status-cancelled { background: #f5f5f5; color: #999999; }

.card-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.card-label {
  font-size: 24rpx;
  color: #999999;
  width: 72rpx;
  flex-shrink: 0;
}

.card-value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}

.card-value.accent { color: #b8860b; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
  gap: 16rpx;
}

.empty-icon { font-size: 80rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; }
.empty-sub { font-size: 26rpx; color: #999999; }
