<view class="page-container">
  <!-- Status Tabs -->
  <scroll-view class="status-tabs" scroll-x>
    <view class="tab-list">
      <view
        wx:for="{{statusTabs}}"
        wx:key="value"
        class="tab {{activeStatus === item.value ? 'active' : ''}}"
        bindtap="onStatusFilter"
        data-value="{{item.value}}"
      >{{item.label}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{isLoading}}" class="empty-state">
    <text class="empty-sub">加载中...</text>
  </view>

  <view wx:elif="{{orders.length === 0}}" class="empty-state">
    <text class="empty-icon">📷</text>
    <text class="empty-title">暂无订单</text>
    <text class="empty-sub">快去预约一次专属拍摄吧</text>
    <button class="btn btn-primary mt-lg" bindtap="goToBooking">立即预约</button>
  </view>

  <view wx:else class="order-list">
    <view
      wx:for="{{orders}}"
      wx:key="_id"
      class="order-card"
      bindtap="onOrderTap"
      data-id="{{item._id}}"
    >
      <view class="card-header">
        <text class="client-name">{{item.clientName}}</text>
        <view class="status-badge status-{{item.status}}">{{item.statusLabel}}</view>
      </view>
      <view class="card-row">
        <text class="card-label">日期</text>
        <text class="card-value">{{item.preferredDate}} {{item.preferredTime}}</text>
      </view>
      <view class="card-row" wx:if="{{item.locationName}}">
        <text class="card-label">地点</text>
        <text class="card-value">{{item.locationName}}</text>
      </view>
      <view class="card-row" wx:if="{{item.characterName}}">
        <text class="card-label">角色</text>
        <text class="card-value accent">{{item.characterName}}</text>
      </view>
    </view>
  </view>
</view>
