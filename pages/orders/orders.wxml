<view class="page-container">
  <!-- Status Tabs -->
  <scroll-view class="status-tabs" scroll-x>
    <view class="tab-list">
      <view
        wx:for="{{statusTabs}}"
        wx:key="value"
        class="tab {{activeStatus === item.value ? 'active' : ''}}"
        bindtap="onStatusFilter"
        data-value="{{item.value}}"
      >{{item.label}}</view>
    </view>
  </scroll-view>

  <loading-skeleton wx:if="{{isLoading}}" type="order-list" count="3" />

  <view wx:elif="{{orders.length === 0}}" class="empty-state">
    <text class="empty-icon">📷</text>
    <text class="empty-title">暂无订单</text>
    <text class="empty-sub">快去预约一次专属拍摄吧</text>
    <button class="btn btn-primary mt-lg" bindtap="goToBooking">立即预约</button>
  </view>

  <view wx:else class="order-list">
    <order-card
      wx:for="{{orders}}"
      wx:key="orderId"
      item="{{item}}"
      bind:tap="onOrderTap"
    />
  </view>
</view>
