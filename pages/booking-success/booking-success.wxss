.success-page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  padding: 80rpx 48rpx 48rpx;
}

.success-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding-bottom: 60rpx;
}

.success-icon { font-size: 120rpx; }
.success-title { font-size: 48rpx; font-weight: 700; color: #1a1a1a; }
.success-sub { font-size: 28rpx; color: #666666; text-align: center; }
.order-num { font-size: 24rpx; color: #999999; margin-top: 8rpx; }

.reminder-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #f8f6f2;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 40rpx;
  border: 2rpx solid #e8ddd0;
}

.reminder-card.subscribed { border-color: #c8a97e; }

.reminder-icon { font-size: 44rpx; }
.reminder-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.reminder-title { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.reminder-sub { font-size: 22rpx; color: #999999; }

.subscribe-btn {
  font-size: 26rpx;
  font-weight: 600;
  color: #c8a97e;
  padding: 12rpx 24rpx;
  border: 2rpx solid #c8a97e;
  border-radius: 9999rpx;
}

.actions { display: flex; flex-direction: column; gap: 16rpx; }
.actions .btn { width: 100%; }
