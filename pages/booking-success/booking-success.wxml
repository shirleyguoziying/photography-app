<view class="success-page">
  <view class="success-content">
    <view class="success-icon">✅</view>
    <text class="success-title">预约成功！</text>
    <text class="success-sub">摄影师将在24小时内确认您的预约</text>
    <text class="order-num">订单号：{{orderId}}</text>
  </view>

  <view class="reminder-card" wx:if="{{!reminderSubscribed}}" bindtap="subscribeReminder">
    <view class="reminder-icon">🔔</view>
    <view class="reminder-text">
      <text class="reminder-title">开启拍摄提醒</text>
      <text class="reminder-sub">拍摄前24小时发送消息提醒</text>
    </view>
    <text class="subscribe-btn">开启</text>
  </view>

  <view class="reminder-card subscribed" wx:else>
    <view class="reminder-icon">✅</view>
    <view class="reminder-text">
      <text class="reminder-title">已开启拍摄提醒</text>
      <text class="reminder-sub">将在拍摄前24小时发送提醒</text>
    </view>
  </view>

  <view class="actions">
    <button class="btn btn-primary" bindtap="goToOrders">查看我的订单</button>
    <button class="btn btn-ghost" bindtap="goHome">返回首页</button>
  </view>
</view>
